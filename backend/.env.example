# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these from your Supabase project dashboard
# https://app.supabase.com/project/_/settings/api

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase public anon key (safe to expose, used by frontend)
SUPABASE_ANON_KEY=your_public_anon_key_here

# Supabase service role key (KEEP SECRET - backend only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase JWT Secret (from Project Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ========================================
# JWT CONFIGURATION
# ========================================

# JWT expiration time
JWT_EXPIRY=7d

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Node environment (development, production, test)
NODE_ENV=development

# ========================================
# LOGGING
# ========================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info